# 数据库配置（PostgreSQL 或 MySQL，通过 DATABASE_URL 格式区分）
# PostgreSQL: postgresql://user:password@localhost:5432/dbname
# MySQL: mysql://user:password@localhost:3306/dbname
DATABASE_URL=""

# 管理员初始化（首次启动时自动创建）
ADMIN_USERNAME="admin"
# 必须设置，否则管理员无法登录
ADMIN_PASSWORD=""

# JWT 密钥（用于管理员登录 Token 签名）
# 必须设置，否则管理后台无法使用
# 建议至少 32 字节随机字符串，可使用 openssl rand -base64 32 生成
JWT_SECRET=""

# JWKS 密钥（可选，用于 RS256 非对称加密）
# JWKS_KEY=""

# 应用端口
PORT=3000

# 系统通知配置（可选）
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM=""
