#!/bin/sh
# Pre-commit 钩子：提交前检查新无服务器代码质量
# 检查内容：Worker + Frontend TypeScript 类型检查 + ESLint

echo "🔍 [pre-commit] 开始代码质量检查..."

# 1. Worker TypeScript 类型检查
echo "📝 [pre-commit] 检查 Worker TypeScript..."
cd worker && npx tsc --noEmit 2>&1
if [ $? -ne 0 ]; then
  echo "❌ [pre-commit] Worker TypeScript 类型检查失败，提交被阻止"
  exit 1
fi
cd ..
echo "✅ [pre-commit] Worker TypeScript 通过"

# 2. Frontend TypeScript 类型检查
echo "📝 [pre-commit] 检查 Frontend TypeScript..."
cd frontend && npx tsc --noEmit 2>&1
if [ $? -ne 0 ]; then
  echo "❌ [pre-commit] Frontend TypeScript 类型检查失败，提交被阻止"
  exit 1
fi
cd ..
echo "✅ [pre-commit] Frontend TypeScript 通过"

# 3. Worker ESLint
echo "🔍 [pre-commit] 检查 Worker ESLint..."
cd worker && npx eslint src/ 2>&1
if [ $? -ne 0 ]; then
  echo "❌ [pre-commit] Worker ESLint 检查失败，提交被阻止"
  exit 1
fi
cd ..
echo "✅ [pre-commit] Worker ESLint 通过"

# 4. Frontend ESLint（如果配置了 eslint）
if [ -f "frontend/eslint.config.mjs" ] || [ -f "frontend/.eslintrc*" ]; then
  echo "🔍 [pre-commit] 检查 Frontend ESLint..."
  cd frontend && npx eslint src/ 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ [pre-commit] Frontend ESLint 检查失败，提交被阻止"
    exit 1
  fi
  cd ..
  echo "✅ [pre-commit] Frontend ESLint 通过"
fi

echo "🎉 [pre-commit] 所有检查通过，允许提交"
