{
  "name": "fiammetta-watcher",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build && mv .open-next/worker.js .open-next/_worker.js && cp -r .open-next/assets/* .open-next/ && node -e \"require('fs').writeFileSync('.open-next/_routes.json', JSON.stringify({version:1,include:['/*'],exclude:['/_next/static/*','/favicon.ico','/robots.txt','/sitemap.xml','/BUILD_ID']},null,2))\"",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run build:cf && wrangler pages deploy .open-next --project-name fiammetta-watcher --branch main",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@cloudflare/workers-types": "^5.20260721.1",
    "antd": "^6.5.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "jose": "^6.2.4",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "next": "^16.2.11",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-i18next": "^17.0.10",
    "recharts": "^3.10.0",
    "tailwind-merge": "^3.6.0"
  },
  "optionalDependencies": {
    "mysql2": "^3.23.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opennextjs/cloudflare": "^1.9.2",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dayjs": "^1.11.21",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.21",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  }
}
