{
  "name": "fiammetta-watcher-proxy",
  "version": "2.0.0",
  "private": true,
  "description": "OpenAI API 中转站路由代理 — Cloudflare Workers 版本",
  "scripts": {
    "dev:worker": "cd worker && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:frontend\"",
    "build:worker": "cd worker && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "deploy:worker": "cd worker && npm run deploy",
    "deploy:frontend": "cd frontend && npm run deploy",
    "db:init": "cd worker && npm run db:init",
    "lint": "cd worker && npx tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
