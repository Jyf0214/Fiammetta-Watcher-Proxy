{
  "name": "fiammetta-watcher-proxy",
  "version": "1.0.0",
  "private": true,
  "proxy": "src/proxy.ts",
  "scripts": {
    "dev": "next dev",
    "prebuild": "test -f src/proxy.ts || (echo '[错误] src/proxy.ts 不存在，proxy 中间件被删除，请恢复' && exit 1)",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint src/",
    "test": "vitest run --exclude='tmp/**' --exclude='.next/**'",
    "prepare": "git config core.hooksPath .githooks",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.1",
    "@lobehub/ui": "^5.20.3",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/postcss": "^4.3.1",
    "antd": "^6.4.5",
    "antd-style": "^4.1.0",
    "clsx": "^2.1.1",
    "https-proxy-agent": "^9.1.0",
    "i18next": "^26.3.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "next": "^16.2.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "recharts": "^3.9.2",
    "socks-proxy-agent": "^10.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.25.1",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
