// Fiammetta Watcher Proxy — Prisma Schema
// 数据库仅用于授权验证、管理员身份校验、必要的草稿存储与最小化运行支撑
// 默认使用 PostgreSQL，MySQL 用户请通过 prisma.config.ts 切换 provider

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 管理员账户 ====================

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]

  @@map("admins")
}

// ==================== 上游平台 ====================

model Platform {
  id           String   @id @default(cuid())
  name         String
  baseUrl      String
  apiKey       String   // 主密钥
  apiKeys      String   @default("[]") // 附加密钥（JSON 数组），与主密钥一起轮询
  type         String   @default("openai") // openai | azure | custom
  enabled      Boolean  @default(true)
  priority     Int      @default(0) // 数值越大优先级越高
  weight       Int      @default(1) // 负载均衡权重
  rpmLimit     Int?     // 每分钟请求限制
  tpmLimit     Int?     // 每分钟 token 限制
  status       String   @default("healthy") // healthy | degraded | down
  failCount    Int      @default(0) // 连续失败次数
  lastFailAt   DateTime?
  cooldownEnd  DateTime? // 熔断冷却结束时间
  forwardHeaders String @default("[]") // 透传给上游的下游请求头白名单（JSON 数组）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  modelMaps  ModelMap[]
  requestLogs RequestLog[]
  proxies   Proxy[]

  @@index([enabled, status])
  @@map("platforms")
}

// ==================== 代理 ====================

model Proxy {
  id          String   @id @default(cuid())
  address     String   // 格式：http://user:pass@host:port 或 socks5://host:port
  platformId  String   // 绑定到特定平台
  enabled     Boolean  @default(true)
  status      String   @default("healthy") // healthy | degraded | down
  failCount   Int      @default(0) // 连续失败次数
  lastFailAt  DateTime?
  cooldownEnd DateTime? // 熔断冷却结束时间（封禁 30 分钟）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  platform Platform @relation(fields: [platformId], references: [id])

  @@index([platformId, enabled, status])
  @@map("proxies")
}

// ==================== API Key ====================

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique
  name       String
  planId     String?   // 可选：关联套餐模板
  quota      Decimal?  @default(0) // 自定义额度（null 表示使用 Plan 默认值）
  usedTokens BigInt   @default(0) // 已使用 token 数
  rpmLimit   Int?      // 每分钟请求限制（null 表示使用 Plan 默认值）
  tpmLimit   Int?      // 每分钟 token 限制（null 表示使用 Plan 默认值）
  callLimit  Int?      // 总调用次数限制（null 表示使用 Plan 默认值）
  tokenLimit BigInt?   // 总 token 限制（null 表示使用 Plan 默认值）
  resetPeriod String?  @default("monthly") // monthly | daily | never
  status     String    @default("active") // active | disabled | expired
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  plan       Plan?      @relation(fields: [planId], references: [id])
  requestLogs RequestLog[]

  @@index([status, expiresAt])
  @@map("api_keys")
}

// ==================== 套餐模板 ====================

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique
  tokenQuota  BigInt   // 总 token 额度
  callLimit   Int      // 总调用次数限制
  rpmLimit    Int      // 每分钟请求限制
  tpmLimit    Int      // 每分钟 token 限制
  resetPeriod String   @default("monthly") // monthly | daily | never
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apiKeys ApiKey[]

  @@map("plans")
}

// ==================== 模型映射 ====================

model ModelMap {
  id          String   @id @default(cuid())
  alias       String   // 客户端请求的模型名（别名）
  targetModel String   // 实际转发到上游的模型名
  platformId  String?  // 绑定到特定平台（null 表示使用路由引擎自动选择）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  platform Platform? @relation(fields: [platformId], references: [id])

  @@unique([alias, platformId])
  @@map("model_maps")
}

// ==================== 请求日志 ====================

model RequestLog {
  id               String   @id @default(cuid())
  keyId            String?
  platformId       String?
  model            String
  status           Int      // HTTP 状态码
  tokens           Int      @default(0) // token 总用量（prompt + completion）
  promptTokens     Int      @default(0) // 输入 token 数
  completionTokens Int      @default(0) // 输出 token 数
  ttft             Int      @default(0) // 首个 token 时间（毫秒），仅流式响应有效
  duration         Int      @default(0) // 耗时（毫秒）
  isError          Boolean  @default(false)
  errorMessage     String?
  createdAt        DateTime @default(now())

  key      ApiKey?    @relation(fields: [keyId], references: [id])
  platform Platform?  @relation(fields: [platformId], references: [id])

  @@index([keyId])
  @@index([platformId])
  @@index([createdAt])
  @@index([keyId, createdAt]) // 按 API Key 查询某时间段请求日志（与 PostgreSQL 版同步）
  @@index([platformId, createdAt]) // 按平台查询某时间段请求日志
  @@map("request_logs")
}

// ==================== 审计日志 ====================

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String   // 操作类型（login, create_platform, update_key 等）
  detail    String?  @db.Text // 操作详情（JSON），可能包含大量变更记录
  ip        String?
  createdAt DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== 系统事件 ====================

model SystemEvent {
  id        String   @id @default(cuid())
  level     String   // info | warning | error | critical
  message   String
  detail    String?  @db.Text // 详细信息（JSON），可能包含大量错误堆栈
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
  @@map("system_events")
}

// ==================== 系统配置 ====================

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("configs")
}
