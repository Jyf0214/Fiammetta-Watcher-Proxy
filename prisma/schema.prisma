// Fiammetta Watcher Proxy — Prisma Schema
// 数据库仅用于授权验证、管理员身份校验、必要的草稿存储与最小化运行支撑
// provider 由 docker-entrypoint.sh 根据 DATABASE_URL 协议自动切换
// 默认使用 MySQL，PostgreSQL 用户请在 Docker 启动时自动切换

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 管理员账户 ====================

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]

  @@map("admins")
}

// ==================== 上游平台 ====================

model Platform {
  id          String    @id @default(cuid())
  name        String
  baseUrl     String   @db.VarChar(2048)
  apiKey      String   @db.VarChar(512) // 主密钥（显式长度，防止 Azure JWT 等超长密钥截断）
  apiKeys     String    @db.Text // 附加密钥（JSON 数组），与主密钥一起轮询（MySQL TEXT 列不允许 DEFAULT，应用层保证默认值 "[]"）
  type        String    @default("openai") // openai | azure | custom
  enabled     Boolean   @default(true)
  priority    Int       @default(0) // 数值越大优先级越高
  weight      Int       @default(1) // 负载均衡权重
  rpmLimit    Int? // 每分钟请求限制
  tpmLimit    Int? // 每分钟 token 限制
  status      String    @default("healthy") // healthy | degraded | down
  failCount   Int       @default(0) // 连续失败次数
  lastFailAt  DateTime?
  cooldownEnd DateTime? // 熔断冷却结束时间
  forwardHeaders String @db.Text // 透传给上游的下游请求头白名单（JSON 数组）（MySQL TEXT 列不允许 DEFAULT，应用层保证默认值 "[]"）
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  modelMaps   ModelMap[]
  requestLogs RequestLog[]
  models      PlatformModel[]

  @@index([enabled, status])
  @@map("platforms")
}

// ==================== 代理池 ====================

model ProxyPool {
  id        String   @id @default(cuid())
  name      String   @unique
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proxies Proxy[]

  @@map("proxy_pools")
}

// ==================== 代理 ====================

model Proxy {
  id          String    @id @default(cuid())
  address     String   @db.VarChar(1024) // 格式：http://user:pass@host:port 或 socks5://host:port
  poolId      String? // 归属代理池（null = 未分组）
  enabled     Boolean   @default(true)
  status      String    @default("healthy") // healthy | degraded | down
  failCount   Int       @default(0) // 恢复计数（degraded 状态下用于渐进恢复）
  banCount    Int       @default(0) // 累计封禁次数（决定递增封禁时长：0→15分钟，1→5小时，≥2→24小时）
  lastFailAt  DateTime?
  cooldownEnd DateTime? // 封禁截止时间；过期后进入"未使用"状态，需自动测试通过才恢复正常
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  pool ProxyPool? @relation(fields: [poolId], references: [id], onDelete: SetNull)

  @@index([poolId, enabled, status])
  @@map("proxies")
}

// ==================== API Key ====================

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String
  planId      String? // 可选：关联套餐模板
  quota       Decimal?  @default(0) @db.Decimal(18, 4) // 自定义额度（null 表示使用 Plan 默认值）
  usedTokens  BigInt    @default(0) // 已使用 token 数
  rpmLimit    Int? // 每分钟请求限制（null 表示使用 Plan 默认值）
  tpmLimit    Int? // 每分钟 token 限制（null 表示使用 Plan 默认值）
  callLimit   Int? // 总调用次数限制（null 表示使用 Plan 默认值）
  tokenLimit  BigInt? // 总 token 限制（null 表示使用 Plan 默认值）
  resetPeriod String?   @default("monthly") // monthly | daily | never
  status      String    @default("active") // active | disabled | expired
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plan        Plan?        @relation(fields: [planId], references: [id])
  requestLogs RequestLog[]

  @@index([status, expiresAt])
  @@map("api_keys")
}

// ==================== 套餐模板 ====================

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique
  tokenQuota  BigInt // 总 token 额度
  callLimit   Int // 总调用次数限制
  rpmLimit    Int // 每分钟请求限制
  tpmLimit    Int // 每分钟 token 限制
  resetPeriod String   @default("monthly") // monthly | daily | never
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apiKeys ApiKey[]

  @@map("plans")
}

// ==================== 模型映射 ====================

model ModelMap {
  id          String   @id @default(cuid())
  alias       String // 客户端请求的模型名（别名）
  targetModel String // 实际转发到上游的模型名
  platformId  String? // 绑定到特定平台（null 表示使用路由引擎自动选择）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  platform Platform? @relation(fields: [platformId], references: [id])

  @@unique([alias, platformId])
  @@map("model_maps")
}

// ==================== 平台模型（自动发现） ====================

model PlatformModel {
  id         String   @id @default(cuid())
  platformId String
  modelId    String   @db.VarChar(255) // 模型 ID（如 gpt-4o, meta/llama-3.1-8b-instruct）
  ownedBy    String?  @db.VarChar(255) // 模型归属（上游返回的 owned_by）
  type       String   @default("chat") // chat | image | audio | embedding
  source     String   @default("auto") // auto = 自动拉取, manual = 用户手动添加
  fetchedAt  DateTime @default(now()) // 最近一次发现时间

  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([platformId, modelId])
  @@index([platformId])
  @@index([modelId])
  @@map("platform_models")
}

// ==================== 请求日志 ====================

model RequestLog {
  id               String   @id @default(cuid())
  keyId            String?
  platformId       String?
  proxyId          String? // 使用的代理 ID（null = 直连）
  model            String
  status           Int // HTTP 状态码
  tokens           Int      @default(0) // token 总用量（prompt + completion）
  promptTokens     Int      @default(0) // 输入 token 数
  completionTokens Int      @default(0) // 输出 token 数
  ttft             Int      @default(0) // 首个 token 时间（毫秒），仅流式响应有效
  duration         Int      @default(0) // 耗时（毫秒）
  isError          Boolean  @default(false)
  errorMessage     String?  @db.Text
  createdAt        DateTime @default(now())

  key      ApiKey?   @relation(fields: [keyId], references: [id])
  platform Platform? @relation(fields: [platformId], references: [id])

  @@index([keyId])
  @@index([platformId])
  @@index([createdAt])
  @@index([keyId, createdAt])
  @@index([platformId, createdAt]) // 按平台查询某时间段请求日志
  @@map("request_logs")
}

// ==================== 审计日志 ====================

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String // 操作类型（login, create_platform, update_key 等）
  detail    String? @db.Text // 操作详情（JSON）
  ip        String?
  createdAt DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== 系统事件 ====================

model SystemEvent {
  id        String   @id @default(cuid())
  level     String // info | warning | error | critical
  message   String   @db.Text
  detail    String?  @db.Text // 详细信息（JSON）
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
  @@map("system_events")
}

// ==================== 系统配置 ====================

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("configs")
}

// ==================== 日志聚合统计（30 天前自动归档） ====================

model DailyStats {
  id                    String   @id @default(cuid())
  date                  DateTime @db.Date // 聚合日期（仅日期部分）
  keyId                 String? // API Key ID（null = 无 Key 请求）
  keyName               String? // 冗余 Key 名称（Key 可能被删除）
  platformId            String? // 平台 ID
  platformName          String? // 冗余平台名称
  model                 String   // 模型名称
  totalRequests         Int      @default(0) // 总请求数
  errorRequests         Int      @default(0) // 错误请求数
  totalTokens           Int      @default(0) // 总 token（prompt + completion）
  totalPromptTokens     Int      @default(0) // 总输入 token
  totalCompletionTokens Int      @default(0) // 总输出 token
  avgTtft               Float    @default(0) // 平均首 token 延迟（毫秒）
  avgDuration           Float    @default(0) // 平均耗时（毫秒）
  maxTtft               Int      @default(0) // 最大首 token 延迟
  maxDuration           Int      @default(0) // 最大耗时

  @@unique([date, keyId, model])
  @@index([date])
  @@index([keyId, date])
  @@index([platformId, date])
  @@map("daily_stats")
}
